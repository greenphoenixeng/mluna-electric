        <path d="M 52,5 L 3,46 L 3,108 L 30,108 L 30,70 L 74,70 L 74,108 L 101,108 L 101,46 Z" fill="#0E0E0E" stroke="#FF672B" stroke-width="7.5" stroke-linejoin="round" stroke-linecap="round"/>
        <rect x="121" y="51" width="7" height="19" rx="3" fill="#FF672B"/>
        <rect x="136" y="51" width="7" height="19" rx="3" fill="#FF672B"/>
        <rect x="114" y="70" width="36" height="16" rx="8" fill="#0E0E0E" stroke="#FF672B" stroke-width="6.5"/>
