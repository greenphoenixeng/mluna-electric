---
import { Image } from 'astro:assets';
import heroBg from '@/assets/images/Gemini-hero.png';
---
<section class="hero" id="home">
  <div class="hero-bg">
    <Image src={heroBg} alt="" class="hero-bg-img" />
    <div class="hero-bg-overlay"></div>
  </div>
  <div class="hero-grid"></div>

  <svg class="hero-bolt-deco" viewBox="0 0 300 500" fill="none" xmlns="http://www.w3.org/2000/svg">
    <polygon points="180,10 60,240 145,240 120,490 240,200 155,200" fill="#FF672B"/>
  </svg>

  <div class="hero-content">
    <div class="hero-badge">PA Master Licensed · Kennett Square, PA</div>
    <h1>Wired Right.<br/>The First <em>Time.</em></h1>
    <p class="hero-sub">
      Chester County's trusted electrical contractor since 2004. Master licensed, family-owned, 9-person crew — residential panels to full commercial builds, done right across Chester &amp; Delaware County.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 010 1.18 2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14v2.92z"/></svg>
        Get a Free Quote
      </a>
      <a href="#services" class="btn-ghost">
        Our Services
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num">20+</div>
        <div class="hero-stat-label">Years Experience</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">9</div>
        <div class="hero-stat-label">Team Members</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">5</div>
        <div class="hero-stat-label">Service Trucks</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">2</div>
        <div class="hero-stat-label">Counties Served</div>
      </div>
    </div>
  </div>
</section>
