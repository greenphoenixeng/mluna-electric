<section class="about" id="about">
  <div class="about-inner">
    <div class="about-visual fade-up">
      <div class="about-img-wrap">
        <img src="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=800&auto=format&fit=crop&q=80" alt="Electrician working on panel" />
        <div class="about-img-overlay"></div>
      </div>
      <div class="about-badge">
        <span class="about-badge-num">10+</span>
        <span class="about-badge-text">Years Serving<br/>Chester County</span>
      </div>
    </div>

    <div class="about-content fade-up">
      <div class="section-label">About M. Luna Electric</div>
      <h2 class="section-title">Built on<br/>Craftsmanship &amp;<br/>Reliability</h2>
      <p class="section-sub">
        M. Luna Electric is a family-owned electrical contractor based in Kennett Square, PA. We've been serving homeowners, property managers, and general contractors across Chester and Delaware County with honest work and real expertise.
      </p>
      <ul class="about-list">
        <li>Licensed, bonded, and insured in Pennsylvania</li>
        <li>Residential, commercial, and new construction experience</li>
        <li>Clean installs — we respect your space and clean up before we leave</li>
        <li>Straightforward pricing with no hidden fees</li>
        <li>Bilingual team — English &amp; Spanish</li>
      </ul>
      <a href="#contact" class="btn-primary">
        Request a Free Quote
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>
