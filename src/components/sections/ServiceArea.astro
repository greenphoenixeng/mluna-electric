---
---
<section class="area" id="area">
  <div class="area-inner">
    <div class="area-map fade-up">
      <div class="area-map-pin">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
      </div>
      <div class="area-map-title">Kennett Square, PA</div>
      <div class="area-map-sub">Serving Chester &amp; Delaware County</div>
      <div class="area-towns">
        <span class="area-town">Kennett Square</span>
        <span class="area-town">West Chester</span>
        <span class="area-town">Coatesville</span>
        <span class="area-town">Phoenixville</span>
        <span class="area-town">Downingtown</span>
        <span class="area-town">Malvern</span>
        <span class="area-town">Media</span>
        <span class="area-town">Newtown Square</span>
        <span class="area-town">Havertown</span>
        <span class="area-town">Exton</span>
        <span class="area-town">Oxford</span>
        <span class="area-town">Avondale</span>
      </div>
    </div>

    <div class="area-content fade-up">
      <div class="section-label">Service Area</div>
      <h2 class="section-title">Serving the<br/>Greater Philly<br/>Suburbs</h2>
      <p class="section-sub">
        Based out of Kennett Square, we run jobs throughout Chester and Delaware County — residential neighborhoods, commercial corridors, and new development sites alike.
      </p>
      <div class="area-features">
        <div class="area-feature">
          <div class="area-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <span>Fast response — most jobs scheduled within the week</span>
        </div>
        <div class="area-feature">
          <div class="area-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <span>No travel surcharge within Chester &amp; Delaware County</span>
        </div>
        <div class="area-feature">
          <div class="area-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <span>Emergency and after-hours availability for existing clients</span>
        </div>
        <div class="area-feature">
          <div class="area-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <span>On GC bid lists for residential &amp; light commercial builds</span>
        </div>
      </div>
    </div>
  </div>
</section>
