---
const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-white/70 py-12">
  <div class="container-lg">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <p class="text-white font-heading font-bold text-lg mb-2">
          <span class="text-electric-400">⚡</span> M Luna Electric
        </p>
        <p class="text-sm">Licensed electrical contractor serving Austin, TX and surrounding areas.</p>
        <p class="text-sm mt-2">License #: TBD</p>
      </div>

      <!-- Quick links -->
      <div>
        <p class="text-white font-semibold mb-3">Quick Links</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="/gallery" class="hover:text-white transition-colors">Gallery</a></li>
          <li><a href="/estimator" class="hover:text-white transition-colors">Get an Estimate</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-white font-semibold mb-3">Contact</p>
        <ul class="space-y-2 text-sm">
          <li>📞 <a href="tel:TBD" class="hover:text-white transition-colors">TBD</a></li>
          <li>✉️ <a href="mailto:TBD" class="hover:text-white transition-colors">TBD</a></li>
          <li>📍 Austin, TX</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row justify-between items-center gap-2 text-xs">
      <p>© {year} M Luna Electric. All rights reserved.</p>
      <p>Website by <a href="https://greenphoenixengineering.com" class="hover:text-white transition-colors">Green Phoenix Engineering</a></p>
    </div>
  </div>
</footer>
