---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Contact M Luna Electric | Free Estimates — Austin, TX"
  description="Contact M Luna Electric for a free electrical estimate. Serving Austin, TX and surrounding areas."
>
  <Nav />

  <main class="pt-16">
    <section class="bg-navy-900 py-20 text-white">
      <div class="container-lg">
        <h1 class="section-heading text-white mb-4">Get in Touch</h1>
        <p class="text-white/70 max-w-xl text-lg">We respond within one business day. Free estimates on all projects.</p>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="container-lg">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <!-- Form -->
          <div>
            <h2 class="text-2xl font-heading font-bold text-navy-800 mb-6">Request a Free Estimate</h2>
            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                  <input type="text" id="name" name="name" required
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-electric-400 focus:border-transparent" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                  <input type="tel" id="phone" name="phone"
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-electric-400 focus:border-transparent" />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                <input type="email" id="email" name="email" required
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-electric-400 focus:border-transparent" />
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service Type</label>
                <select id="service" name="service"
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-electric-400 focus:border-transparent">
                  <option value="">Select a service...</option>
                  <option>Residential – Panel / Wiring</option>
                  <option>Residential – Outlets / Lighting</option>
                  <option>Residential – EV Charger</option>
                  <option>Commercial – Buildout</option>
                  <option>Commercial – Service / Repair</option>
                  <option>Service Call / Troubleshooting</option>
                  <option>Other</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Tell us about your project *</label>
                <textarea id="message" name="message" rows="4" required
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-electric-400 focus:border-transparent resize-none"
                  placeholder="Describe what you need..."></textarea>
              </div>
              <button type="submit" class="btn-primary w-full justify-center">
                Send Request
              </button>
              <p id="form-status" class="text-sm text-center hidden"></p>
            </form>
          </div>

          <!-- Contact info -->
          <div class="space-y-8">
            <div>
              <h2 class="text-2xl font-heading font-bold text-navy-800 mb-6">Contact Info</h2>
              <ul class="space-y-4 text-gray-700">
                <li class="flex items-start gap-3">
                  <span class="text-electric-400 text-xl">📞</span>
                  <div>
                    <p class="font-semibold">Phone</p>
                    <a href="tel:TBD" class="text-navy-700 hover:underline">TBD</a>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-electric-400 text-xl">✉️</span>
                  <div>
                    <p class="font-semibold">Email</p>
                    <a href="mailto:TBD" class="text-navy-700 hover:underline">TBD</a>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-electric-400 text-xl">📍</span>
                  <div>
                    <p class="font-semibold">Service Area</p>
                    <p>Austin, TX and surrounding areas</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-electric-400 text-xl">🕒</span>
                  <div>
                    <p class="font-semibold">Hours</p>
                    <p>Mon–Fri: 7am – 6pm</p>
                    <p>Sat: 8am – 3pm</p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    status.textContent = 'Sending...';
    status.classList.remove('hidden', 'text-red-600', 'text-green-600');
    status.classList.add('text-gray-500');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        status.textContent = '✓ Message sent! We\'ll be in touch within one business day.';
        status.classList.replace('text-gray-500', 'text-green-600');
        form.reset();
      } else {
        throw new Error('Server error');
      }
    } catch {
      status.textContent = 'Something went wrong. Please call or email us directly.';
      status.classList.replace('text-gray-500', 'text-red-600');
    }
  });
</script>
