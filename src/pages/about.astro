---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { Image } from 'astro:assets';

import photo272 from '@/assets/images/IMG_0272.jpeg';
import photo267 from '@/assets/images/IMG_0267.jpeg';
import photo163 from '@/assets/images/IMG_0163.jpeg';
import moema15 from '@/assets/images/moema-15.jpg';
---

<Layout
  title="About M. Luna Electric | Licensed Electrician — Kennett Square, PA"
  description="M. Luna Electric is a family-owned electrical contractor based in Kennett Square, PA with 20+ years serving Chester & Delaware County. Master licensed, bilingual, 9-person crew."
>
  <Nav />

  <div class="about-pg-hero">
    <div class="about-pg-hero-inner">
      <div class="section-label">About Us</div>
      <h1 class="section-title">Built on<br/>Craftsmanship<br/>&amp; Reliability</h1>
      <p class="section-sub">Family-owned. Kennett Square-based. Over a decade of honest electrical work across Chester and Delaware County.</p>
    </div>
  </div>

  <section class="about-pg-story">
    <div class="about-pg-story-inner">
      <div class="about-pg-photo fade-up">
        <div class="about-pg-img-wrap">
          <Image src={moema15} alt="M. Luna Electric crew on a Kennett Square project" />
          <div class="about-pg-overlay"></div>
        </div>
        <div class="about-pg-badge">
          <span class="about-pg-badge-num">20+</span>
          <span class="about-pg-badge-text">Years Serving<br/>Chester County</span>
        </div>
      </div>

      <div class="about-pg-text fade-up">
        <div class="section-label">Our Story</div>
        <h2 class="section-title" style="font-size: clamp(36px,5vw,56px);">Built from<br/>the Ground Up</h2>
        <p class="section-sub"><strong style="color:var(--orange);font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:.08em;text-transform:uppercase;">The Foundation (2004–2017)</strong><br/>
          Miguel Luna Cruz began his electrical journey in 2004, spending over a decade mastering the trade's complexities. His dedication culminated in 2018 when he earned his Master Electrician license — providing the foundation to launch M. Luna Electric as a solo operation with one truck.
        </p>
        <p class="section-sub" style="margin-top: 20px;"><strong style="color:var(--orange);font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:.08em;text-transform:uppercase;">Growth &amp; Specialization</strong><br/>
          The business found its footing in Kennett Square's mushroom houses, where precision and reliability aren't optional. The reputation built there allowed M. Luna Electric to expand across Chester and Delaware County and eventually serve clients out of state — before officially incorporating.
        </p>
        <p class="section-sub" style="margin-top: 20px;"><strong style="color:var(--orange);font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:.08em;text-transform:uppercase;">M. Luna Electric Today</strong><br/>
          Driven by a loyal and growing client base, the company officially incorporated. Today, M. Luna Electric, Inc. has grown into a team of 9 dedicated employees running 5 fully-equipped service trucks — still family-run, still built on the same principles from day one.
        </p>
        <blockquote class="about-pg-quote">"We are still small, but we hope to grow by continuously helping our clients." — Miguel Luna Cruz</blockquote>
        <div class="about-pg-license fade-up">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          PA Electrical Contractor License: <strong>PA145866</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="about-pg-stats">
    <div class="about-pg-stats-inner">
      <div class="about-pg-stat fade-up">
        <div class="about-pg-stat-num">20+</div>
        <div class="about-pg-stat-label">Years Experience</div>
      </div>
      <div class="about-pg-stat fade-up">
        <div class="about-pg-stat-num">9</div>
        <div class="about-pg-stat-label">Team Members</div>
      </div>
      <div class="about-pg-stat fade-up">
        <div class="about-pg-stat-num">5</div>
        <div class="about-pg-stat-label">Service Trucks</div>
      </div>
      <div class="about-pg-stat fade-up">
        <div class="about-pg-stat-num">2</div>
        <div class="about-pg-stat-label">Counties Served</div>
      </div>
    </div>
  </section>

  <section class="about-pg-values">
    <div class="about-pg-values-inner">
      <div class="about-pg-values-header fade-up">
        <div class="section-label">What We Stand For</div>
        <h2 class="section-title" style="font-size: clamp(36px,5vw,56px);">The Difference<br/>Is in the Details</h2>
      </div>
      <div class="about-pg-values-grid">
        {[
          { num: '01', title: 'On-Time, Every Time',   body: 'We respect your schedule. If we\'re running late, you\'ll hear from us before you have to call.' },
          { num: '02', title: 'Code Compliant',         body: 'Every job done to current NEC and PA state code. We pull permits and pass inspections — no shortcuts.' },
          { num: '03', title: 'Upfront Pricing',        body: 'You know the price before we start. No surprise invoices, no upsells mid-job.' },
          { num: '04', title: 'Bilingual Team',         body: 'We communicate in English and Spanish so nothing gets lost in translation.' },
          { num: '05', title: 'GC-Ready Crew',          body: 'We sequence, communicate, and deliver clean rough-ins that pass every time.' },
          { num: '06', title: 'Local &amp; Accountable', body: 'We live here too. Our reputation in Chester County is built one job at a time.' },
        ].map(v => (
          <div class="about-pg-value fade-up">
            <div class="about-pg-value-num">{v.num}</div>
            <div class="about-pg-value-title" set:html={v.title} />
            <p class="about-pg-value-body">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="about-pg-gallery">
    <div class="about-pg-gallery-inner">
      <div class="about-pg-gallery-img fade-up">
        <Image src={photo267} alt="Finished commercial Eaton panel installation" />
      </div>
      <div class="about-pg-gallery-img fade-up">
        <Image src={photo163} alt="Multi-panel commercial system on stone building" />
      </div>
    </div>
  </section>

  <section class="about-pg-mission">
    <div class="about-pg-mission-inner">
      <div class="about-pg-mission-text fade-up">
        <div class="section-label">Our Mission</div>
        <h2 class="section-title" style="font-size: clamp(32px,4.5vw,52px);">Family.<br/>Integrity.<br/>Community.</h2>
        <p class="section-sub" style="margin-top: 24px;">
          At M. Luna Electric, Inc., our business is built on family — and that extends to every client we serve. Miguel's daughter manages the office while pursuing her bachelor's degree. His son is training at Lincoln Tech to become the next generation of Master Electricians.
        </p>
        <p class="section-sub" style="margin-top: 16px;">
          We put our clients' needs before our profits. Whether handling a residential update or a complex commercial project, our job isn't done when the power turns on — we believe in building lasting relationships through dedicated post-project care and reliable service.
        </p>
      </div>
      <div class="about-pg-mission-cards fade-up">
        <div class="about-mission-card">
          <div class="about-mission-card-title">Family-Owned &amp; Operated</div>
          <p class="about-mission-card-body">Three generations of the Luna family invested in every job — from the field to the front office.</p>
        </div>
        <div class="about-mission-card">
          <div class="about-mission-card-title">Clients Before Profits</div>
          <p class="about-mission-card-body">We prioritize your outcome over our margin. Transparent pricing, no upsells mid-job.</p>
        </div>
        <div class="about-mission-card">
          <div class="about-mission-card-title">Post-Project Care</div>
          <p class="about-mission-card-body">The job isn't done when the power turns on. We stand behind our work and maintain the relationship.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="cta-band-inner">
      <h2>Ready to Work<br/>Together?</h2>
      <p>Get a free estimate — we respond within one business day.</p>
      <div class="cta-band-actions">
        <a href="/#contact" class="btn-dark">Request a Free Quote</a>
        <a href="tel:+14846433625" class="btn-white">Call Us Directly</a>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .about-pg-hero {
    background: var(--black);
    padding: 140px 5% 80px;
    border-bottom: 1px solid var(--dark3);
  }
  .about-pg-hero-inner { max-width: 800px; margin: 0 auto; }
  .about-pg-hero .section-title { font-size: clamp(52px, 8vw, 88px); }

  .about-pg-story { background: var(--dark); padding: 100px 5%; }
  .about-pg-story-inner {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
  }
  .about-pg-img-wrap {
    position: relative; border-radius: 4px; overflow: hidden;
    aspect-ratio: 3/4;
  }
  .about-pg-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .about-pg-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(14,14,14,0.5) 0%, transparent 60%);
  }
  .about-pg-badge {
    position: absolute; bottom: 24px; left: 24px;
    background: var(--orange);
    padding: 16px 20px; border-radius: 4px;
    display: flex; flex-direction: column;
  }
  .about-pg-badge-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 40px; font-weight: 800; line-height: 1;
    color: #000;
  }
  .about-pg-badge-text { font-size: 12px; font-weight: 700; color: rgba(0,0,0,0.7); line-height: 1.3; }

  .about-pg-stats { background: var(--black); padding: 60px 5%; border-top: 1px solid var(--dark3); border-bottom: 1px solid var(--dark3); }
  .about-pg-stats-inner {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 0; border-left: 1px solid var(--dark3);
  }
  .about-pg-stat {
    padding: 32px 40px;
    border-right: 1px solid var(--dark3);
  }
  .about-pg-stat-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 52px; font-weight: 800; line-height: 1;
    color: var(--orange); margin-bottom: 8px;
  }
  .about-pg-stat-label { font-size: 14px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }

  .about-pg-values { background: var(--dark2); padding: 100px 5%; }
  .about-pg-values-inner { max-width: 1200px; margin: 0 auto; }
  .about-pg-values-header { margin-bottom: 60px; }
  .about-pg-values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  .about-pg-value {
    background: var(--dark); padding: 40px 32px;
    border: 1px solid var(--dark3);
  }
  .about-pg-value-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px; font-weight: 700; color: var(--orange);
    letter-spacing: 0.1em; margin-bottom: 16px;
  }
  .about-pg-value-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px; font-weight: 800; text-transform: uppercase;
    color: var(--white); margin-bottom: 12px;
  }
  .about-pg-value-body { font-size: 15px; color: var(--muted); line-height: 1.65; }

  .about-pg-gallery { background: var(--black); padding: 0 5% 80px; }
  .about-pg-gallery-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .about-pg-gallery-img { aspect-ratio: 16/9; overflow: hidden; border-radius: 4px; }
  .about-pg-gallery-img img { width: 100%; height: 100%; object-fit: cover; }

  .about-pg-license {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 24px; padding: 12px 18px;
    background: rgba(255,103,43,0.08);
    border: 1px solid rgba(255,103,43,0.25);
    border-radius: 4px;
    font-size: 14px; color: var(--light);
  }
  .about-pg-license svg { color: var(--orange); flex-shrink: 0; }
  .about-pg-license strong { color: var(--orange); }
  .about-pg-quote {
    margin-top: 28px; padding: 20px 24px;
    border-left: 3px solid var(--orange);
    background: rgba(255,103,43,0.04);
    font-size: 16px; font-style: italic; color: var(--light);
    line-height: 1.65; border-radius: 0;
  }

  .about-pg-mission {
    background: var(--dark);
    padding: 100px 5%;
    border-top: 1px solid var(--dark3);
  }
  .about-pg-mission-inner {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;
  }
  .about-pg-mission-cards { display: flex; flex-direction: column; gap: 16px; padding-top: 8px; }
  .about-mission-card {
    padding: 28px 32px;
    background: var(--dark2);
    border: 1px solid var(--dark3);
    border-left: 3px solid var(--orange);
    border-radius: 0;
  }
  .about-mission-card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px; font-weight: 800; text-transform: uppercase;
    color: var(--white); margin-bottom: 8px; letter-spacing: 0.02em;
  }
  .about-mission-card-body { font-size: 15px; color: var(--muted); line-height: 1.65; margin: 0; }

  @media (max-width: 1024px) {
    .about-pg-mission-inner { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 1024px) {
    .about-pg-story-inner { grid-template-columns: 1fr; gap: 48px; }
    .about-pg-stats-inner { grid-template-columns: repeat(2, 1fr); }
    .about-pg-values-grid { grid-template-columns: repeat(2, 1fr); }
    .about-pg-gallery-inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .about-pg-hero { padding: 120px 5% 60px; }
    .about-pg-stats-inner { grid-template-columns: 1fr 1fr; border-left: none; }
    .about-pg-stat { border-left: 1px solid var(--dark3); padding: 24px 20px; }
    .about-pg-values-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>
